# ───────────────────────────────────────────────
# Game Changer — Environment Variables
# העתק קובץ זה ל-.env.local ומלא את הערכים
# (הסקריפט setup.mjs עושה את זה אוטומטית)
# ───────────────────────────────────────────────

# Supabase — New API Keys (2026)
# https://supabase.com/docs/guides/api/api-keys
# Dashboard → Project Settings → API Keys → "Publishable and secret API keys"
NEXT_PUBLIC_SUPABASE_URL=                  # https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=      # sb_publishable_...  (browser-safe)
SUPABASE_SECRET_KEY=                       # sb_secret_...       (server-only, NEVER expose)

# Anthropic — Claude API
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=            # sk-ant-...  (server-only, NEVER expose)

# Vercel AI Gateway
# 5$ קרדיט חינם כל חודש — https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# Google Docs — Service Account
# https://console.cloud.google.com → IAM & Admin → Service Accounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=        # service-account@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=          # -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n (paste as single line, \n literal)

# Google Drive — target folder
# Share this folder with GOOGLE_SERVICE_ACCOUNT_EMAIL (Editor access)
GOOGLE_DRIVE_FOLDER_ID=              # folder ID from the Drive URL

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
